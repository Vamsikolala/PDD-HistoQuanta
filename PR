            .frame(maxWidth: .infinity, alignment: .leading)
            .padding(.leading, 18)
            .padding(.top, 12)
            .padding(.bottom, 20)

            Spacer()

            NavigationLink(destination: PR_HScore(), isActive: $showHScore) { EmptyView() }
