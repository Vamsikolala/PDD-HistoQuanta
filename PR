import SwiftUI

struct PR: View {
    @Environment(\.dismiss) private var dismiss
    @State private var showHScore = false

    let colWidth: CGFloat = 120
    let tableLineColor = Color.black

    var body: some View {
        VStack(spacing: 0) {
            // Top bar
            HStack {
                Button(action: { dismiss() }) {
                    Image(systemName: "arrow.left")
