                        .cornerRadius(3)
                }
            }
            .padding(.trailing, 28)
            .padding(.top, 8)

            VStack(alignment: .leading, spacing: 4) {
                Text("INFERENCE:")
                    .font(.system(size: 16, weight: .bold))
                Text("0-2 NEGATIVE")
