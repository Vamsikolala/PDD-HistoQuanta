import SwiftUI

struct GITBiopsySpecimen: View {
    @Environment(\.dismiss) private var dismiss
    @State private var showGuidelines = false

    var body: some View {
        VStack(spacing: 0) {
            // Top Bar
            HStack {
                Button(action: { dismiss() }) {
                    Image(systemName: "arrow.left")
                        .resizable()
                        .frame(width: 26, height: 26)
                        .foregroundColor(.black)
                }
                Spacer()
                Text("GIT")
                    .font(.system(size: 26, weight: .bold))
                Spacer()
                Button(action: {
                    showGuidelines = true
                }) {
                    Image(systemName: "ellipsis")
                        .font(.system(size: 26, weight: .bold))
                        .foregroundColor(.black)
                }
            }
            .padding([.horizontal, .top], 18)
            .padding(.bottom, 4)
            
            // Subtitle (three lines, centered)
            VStack(spacing: 4) {
                Text("Adenocarcinoma")
                    .font(.system(size: 22))
                    .multilineTextAlignment(.center)
                Text("HER2-Biopsy")
                    .font(.system(size: 20))
                    .multilineTextAlignment(.center)
                Text("Specimen")
                    .font(.system(size: 20))
                    .multilineTextAlignment(.center)
            }
            .padding(.top, 10)
            
            Spacer()
                .frame(height: 60)
            
            // Info Box
            HStack {
                Spacer()
                VStack {
                    Text("""
                        Intensity of staining
                        complete=3+ positive
                        moderate=2+ equivocal
                        incomplete=1+ negative
                        no staining=0 negative
                        """)
                        .font(.system(size: 18))
                        .foregroundColor(.white)
                        .multilineTextAlignment(.center)
                        .padding(.vertical, 22)
                        .padding(.horizontal, 12)
                }
                .background(Color(red: 0.51, green: 0.84, blue: 1.0))
                .cornerRadius(12)
                Spacer()
            }
            .padding(.horizontal, 24)

            Spacer()
            
            NavigationLink(destination: GITguidelinesher2(), isActive: $showGuidelines) {
                EmptyView()
            }
            .hidden()
        }
        .background(Color.white.ignoresSafeArea())
        .navigationBarBackButtonHidden(true)
    }
}

