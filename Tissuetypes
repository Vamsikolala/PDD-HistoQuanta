import SwiftUI

struct Tissue: Identifiable {
    let id = UUID()
    let imageName: String
    let title: String
}

struct Tissuetypes: View {
    let tissues: [Tissue] = [
        Tissue(imageName: "Breast", title: "Breast"),
        Tissue(imageName: "Thyroid", title: "Thyroid"),
        Tissue(imageName: "GIT", title: "GIT"),
        Tissue(imageName: "Soft tissue", title: "Soft Tissue"),
        Tissue(imageName: "Head Neck", title: "Head & Neck"),
        Tissue(imageName: "Lungs", title: "Lungs")
    ]

    @State private var selectedTab = 0
    @Environment(\.dismiss) private var dismiss

    let columns = [
        GridItem(.flexible()),
        GridItem(.flexible())
    ]
    
    var body: some View {
        VStack(spacing: 8) {
            HStack {
                Button(action: { dismiss() }) {
                    Image(systemName: "arrow.left")
                        .font(.system(size: 26, weight: .bold))
                        .foregroundColor(.black)
                        .padding(.leading, 10)
                }
                Spacer()
                Text("Select Tissue")
                    .font(.system(size: 22, weight: .semibold))
                Spacer()
                Color.clear.frame(width: 28, height: 28)
            }
            .padding(.horizontal, 22)
            .padding(.top, 18)
            .padding(.bottom, 8)

            ScrollView {
                LazyVGrid(columns: columns, spacing: 22) {
                    ForEach(tissues) { tissue in
                        switch tissue.title {
                        case "Breast":
                            NavigationLink(destination: Breasttypes()) {
                                tissueTile(for: tissue)
                            }
                        case "Thyroid":
                            NavigationLink(destination: ThyroidKi67()) {
                                tissueTile(for: tissue)
                            }
                        case "GIT":
                            NavigationLink(destination: GITScreen()) {
                                tissueTile(for: tissue)
                            }
                        case "Soft Tissue":
                            NavigationLink(destination: SoftTissue()) {
                                tissueTile(for: tissue)
                            }
                        case "Head & Neck":
                            NavigationLink(destination: HeadNeckScreen()) {
                                tissueTile(for: tissue)
                            }
                        case "Lungs":
                            NavigationLink(destination: LungsHer2()) {
                                tissueTile(for: tissue)
                            }
                        default:
                            tissueTile(for: tissue)
                        }
                    }
                }
                .padding(.horizontal, 12)
                .padding(.top, 12)
            }

            Spacer()

            HStack {
                tabBarItem(systemName: "house", isSelected: selectedTab == 0, label: "Home")
                    .onTapGesture { selectedTab = 0 }
                Spacer()
                tabBarItem(systemName: "magnifyingglass", isSelected: selectedTab == 1, label: "Search")
                    .onTapGesture { selectedTab = 1 }
                Spacer()
                tabBarItem(systemName: "bookmark", isSelected: selectedTab == 2, label: "Favorites")
                    .onTapGesture { selectedTab = 2 }
                Spacer()
                tabBarItem(systemName: "person", isSelected: selectedTab == 3, label: "Profile")
                    .onTapGesture { selectedTab = 3 }
            }
            .padding(.horizontal, 32)
            .padding(.vertical, 6)
            .background(Color(.systemGray6))
        }
        .background(Color(red: 0.94, green: 0.96, blue: 1.0).ignoresSafeArea())
        .navigationBarBackButtonHidden(true)
        .navigationBarHidden(true)
    }

    @ViewBuilder
    func tissueTile(for tissue: Tissue) -> some View {
        VStack(spacing: 12) {
            ZStack {
                Circle()
                    .fill(Color(red: 0.85, green: 0.92, blue: 0.97))
                    .frame(width: 72, height: 72)
                Image(tissue.imageName)
                    .resizable()
                    .scaledToFill()
                    .frame(width: 72, height: 72)
                    .clipShape(Circle())
            }
            Text(tissue.title)
                .font(.system(size: 19, weight: .semibold))
                .foregroundColor(.black)
        }
        .frame(maxWidth: .infinity, minHeight: 128)
        .background(Color.white)
        .cornerRadius(15)
        .shadow(color: Color.black.opacity(0.06), radius: 4, x: 0, y: 2)
        .padding(.horizontal, 2)
    }

    @ViewBuilder
    func tabBarItem(systemName: String, isSelected: Bool, label: String) -> some View {
        VStack(spacing: 2) {
            Image(systemName: systemName)
                .font(.system(size: 22, weight: .regular))
                .foregroundColor(isSelected ? Color.blue : Color.gray)
            Text(label)
                .font(.system(size: 12))
                .foregroundColor(isSelected ? Color.blue : Color.gray)
        }
    }
}

struct Tissuetypes_Previews: PreviewProvider {
    static var previews: some View {
        NavigationStack {
            Tissuetypes()
        }
    }
}
