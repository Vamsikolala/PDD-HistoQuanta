import SwiftUI

struct GISTSelectorScreen: View {
    @Environment(\.dismiss) private var dismiss

    var body: some View {
        VStack(spacing: 0) {
            // Top Bar
            HStack {
                Button(action: { dismiss() }) {
                    Image(systemName: "arrow.left")
                        .resizable()
                        .frame(width: 26, height: 26)
                        .foregroundColor(.black)
                }
                Spacer()
            }
            .padding(.leading, 18)
            .padding(.top, 18)
            .padding(.bottom, 4)

            // Screen Title
            Text("GIT")
                .font(.system(size: 26, weight: .bold))
                .padding(.bottom, 12)

            // Subtitle
            Text("GIST (Gastro Intestinal\nStromal Tumor)")
                .font(.system(size: 18))
                .multilineTextAlignment(.center)
                .padding(.top, 4)

            Spacer().frame(height: 38)

            // Option Buttons
            VStack(spacing: 16) {
                NavigationLink(destination: GIST_KI67Screen()) {
                    Text("KI67")
                        .foregroundColor(.white)
                        .font(.system(size: 18, weight: .medium))
                        .frame(maxWidth: .infinity, minHeight: 48)
                        .background(Color(red: 0.51, green: 0.84, blue: 1.0))
                        .cornerRadius(10)
                }
                NavigationLink(destination: GIST_KITScreen()) {
                    Text("KIT")
                        .foregroundColor(.white)
                        .font(.system(size: 18, weight: .medium))
                        .frame(maxWidth: .infinity, minHeight: 48)
                        .background(Color(red: 0.51, green: 0.84, blue: 1.0))
                        .cornerRadius(10)
                }
            }
            .padding(.horizontal, 24)
            .padding(.top, 16)

            Spacer()
        }
        .background(Color.white.ignoresSafeArea())
        .navigationBarBackButtonHidden(true)
    }
}

