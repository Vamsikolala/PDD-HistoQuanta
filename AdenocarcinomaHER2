import SwiftUI

struct AdenocarcinomaHER2: View {
    @Environment(\.dismiss) private var dismiss
    @State private var navigateToGuidelines = false

    var body: some View {
        VStack(spacing: 0) {
            // Top Bar
            HStack {
                Button(action: { dismiss() }) {
                    Image(systemName: "arrow.left")
                        .resizable()
                        .frame(width: 26, height: 26)
                        .foregroundColor(.black)
                }

                Spacer()

                Text("AdenocarcinomaHER2")
                    .font(.system(size: 23, weight: .bold))
                    .multilineTextAlignment(.center)

                Spacer()

                Button(action: {
                    navigateToGuidelines = true
                }) {
                    Image(systemName: "ellipsis")
                        .font(.system(size: 26, weight: .bold))
                        .foregroundColor(.black)
                }
            }
            .padding([.horizontal, .top], 18)
            .padding(.bottom, 4)

            // Subtitle (two lines, centered)
            VStack(spacing: 4) {
                Text("Adenocarcinoma")
                    .font(.system(size: 22))
                    .multilineTextAlignment(.center)
                Text("HER2- surgical specimen")
                    .font(.system(size: 20))
                    .multilineTextAlignment(.center)
            }
            .padding(.top, 10)

            Spacer()
                .frame(height: 60)

            // Info Box
            HStack {
                Spacer()
                VStack {
                    Text("""
                        Intensity of staining
                        complete =3+ positive
                        moderate=2+ equivocal
                        incomplete=1+ negative
                        no staining=0 negative
                        """)
                        .font(.system(size: 18))
                        .foregroundColor(.white)
                        .multilineTextAlignment(.center)
                        .padding(.vertical, 22)
                        .padding(.horizontal, 12)
                }
                .background(Color(red: 0.51, green: 0.84, blue: 1.0))
                .cornerRadius(12)
                Spacer()
            }
            .padding(.horizontal, 24)

            Spacer()

            // NavigationLink for ellipsis button
            NavigationLink(
                destination: GITGuidelines(),
                isActive: $navigateToGuidelines,
                label: { EmptyView() }
            )
        }
        .frame(maxWidth: .infinity, maxHeight: .infinity, alignment: .top)
        .background(Color.white.ignoresSafeArea())
        .navigationBarBackButtonHidden(true)
    }
}

